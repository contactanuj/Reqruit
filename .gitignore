# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
wheels/
*.egg-info/
*.egg

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
ENV/

# ---------------------------------------------------------------------------
# Environment variables (secrets)
# .env contains API keys and secrets — never commit.
# .env.example is the safe template that IS committed.
# ---------------------------------------------------------------------------
.env
.env.local
.env.production

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Testing & Coverage
# ---------------------------------------------------------------------------
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# ---------------------------------------------------------------------------
# Linting
# ---------------------------------------------------------------------------
.ruff_cache/
.mypy_cache/

# ---------------------------------------------------------------------------
# Docker volumes (local data)
# ---------------------------------------------------------------------------
docker/data/

# ---------------------------------------------------------------------------
# Model cache (HuggingFace downloads BGE model here on first run)
# ---------------------------------------------------------------------------
.cache/

# ---------------------------------------------------------------------------
# AI Assistant context files
# CLAUDE.md contains project context for AI-assisted development sessions.
# Not useful to other contributors and may contain session-specific notes.
# ---------------------------------------------------------------------------
CLAUDE.md

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
*.log
