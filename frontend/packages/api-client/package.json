{
  "name": "@reqruit/api-client",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "generate-types": "openapi-typescript http://localhost:8000/openapi.json -o src/schema.d.ts || (echo 'Warning: Backend unavailable — using committed schema.d.ts' && exit 0)",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "openapi-typescript": "^7.13.0",
    "typescript": "latest"
  }
}
